[
    {hecate_git, [
        {http_port,         8470},
        {data_dir,          "/var/lib/hecate-git/data"},
        {repositories_dir,  "/bulk0/hecate/hecate-git/repositories"},
        {event_store_id,    git_store}
    ]},

    {hecate_om, [
        {service_cert_path, "/etc/hecate/secrets/service-cert.pem"},
        {station_socket,    "/run/macula/station.sock"},
        {health_port,       8470}
    ]}
].
